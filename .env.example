# === Municipio de Mexicali, B.C. ===
MUNICIPALITY_NAME=Mexicali
STATE_NAME="Baja California"

# Centro del mapa (lon, lat) — ajuste si es necesario
DEFAULT_MAP_CENTER_LON=-115.468278
DEFAULT_MAP_CENTER_LAT=32.624639
DEFAULT_MAP_ZOOM=12

# SRID: 4326 almacenamiento GeoJSON | 32611 cálculo de áreas (UTM 11N, origen Mexicali)
GEOGRAPHIC_SRID=4326
METRIC_SRID=32611

# Patrón clave catastral (regex). Capa prediosmxli — campo clavecatas. Ej.: ST002001
CADASTRAL_CODE_PATTERN=^[A-Za-z0-9]{2,3}[0-9]{6}$

# === GeoNode / GeoServer local en VM ===
# Servidor principal GeoNode en la VM: 192.168.116.132
# Use http o https segun su configuracion real.
GEONODE_URL=http://192.168.116.132
GEOSERVER_PATH=/geoserver

# Capas WMS — una sola línea cada variable (sin duplicar; la primera gana en .env)
GEONODE_WMS_LAYERS=geonode:colonias,catastro_bc:predios_oficial,geonode:codigos_postales_bc_utm1
GEONODE_WMS_LAYER_TITLES=Colonias WMS,Predios GeoServer WMS,Códigos postales WMS

# GeoMexicali: las capas requieren permisos — usuario de servicio (solo en servidor)
GEONODE_USER=sgc_web
GEONODE_PASSWORD=cambie_esta_contraseña
# Opcional si GeoServer usa authkey en lugar de Basic Auth:
# GEONODE_AUTH_KEY=
GEONODE_AUTH_REQUIRED=true
# Certificado autofirmado en red local (GeoNode/HTTPS interno)
GEONODE_SSL_VERIFY=false

# === Origen vectorial oficial (cartografía y geometría de predios) ===
# La capa WMS de referencia y la fuente WFS de sincronización son la misma capa.
GEONODE_SOURCE_LAYER=geonode:prediosmxli
GEONODE_SOURCE_TITLE=Predios Mexicali (origen oficial)
GEONODE_SOURCE_SRID=4326
SKIP_DEMO_WHEN_SOURCE_LAYER=true
GEONODE_SYNC_BATCH_SIZE=2000
# Campo único de clave catastral en prediosmxli (GeoServer)
GEONODE_FIELD_CADASTRAL=clavecatas,clavecata,clave_catastral
GEONODE_FIELD_PREDIAL=clavecatas
# GEONODE_FIELD_COLONY=colonia,nom_colonia
# GEONODE_FIELD_ADDRESS=domicilio,direccion
# GEONODE_FIELD_LAND_USE=uso_suelo,uso
# GEONODE_FIELD_AREA=area,superficie,sup_terreno

# === Adeudos tributarios (WFS → predios_alfanumerico) ===
GEONODE_ADEUDO_LAYER=geonode:predios_adeudo_2026
GEONODE_FIELD_ADEUDO_2026=adeudo_2026,adeudo2026,adeudo_ejercicio,adeudo,monto_adeudo
GEONODE_FIELD_ADEUDO_TOTAL=adeudo_total,adeudototal,adeudo_acumulado,total_adeudo
# GEONODE_FIELD_VALOR=valor2026,valor_catastral,avaluo

# === API / base de datos (PostgreSQL de la VM — mismo que GeoNode) ===
# Desde el contenedor API use host.docker.internal (ver docker-compose.yml)
DATABASE_URL=postgresql+psycopg://USUARIO:CLAVE@host.docker.internal:5432/catastro_lab

# === Autenticación SGC-Web ===
JWT_SECRET=genere-una-clave-larga-y-aleatoria
JWT_EXPIRE_MINUTES=480
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CambieAdmin123!
BOOTSTRAP_ADMIN_EMAIL=admin@catastro.local
BOOTSTRAP_ADMIN_FULL_NAME=Administrador SGC
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.116.132:5173
SEED_ON_STARTUP=true

# === Frontend (Vite) ===
# En Docker VM el navegador usa solo el puerto 5173 (Vite proxy /api → api:8000)
VITE_API_PROXY_TARGET=http://api:8000
VITE_API_URL=http://192.168.116.132:8000
